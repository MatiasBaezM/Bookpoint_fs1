{
	"info": {
		"_postman_id": "b00kp01n-fs01-4a1d-9e2c-bookpointchile01",
		"name": "Bookpoint Chile - Microservicios",
		"description": "Colección de pruebas para los 10 microservicios de Bookpoint Chile.\n\nCada carpeta corresponde a un microservicio y usa una variable de base URL propia (definida en el environment 'Bookpoint - Local').\n\nLos tests validan el código de estado HTTP y, en los POST de creación, guardan IDs/folios en variables de colección para encadenar peticiones.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"event": [
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Test global aplicado a TODAS las peticiones",
					"pm.test(\"El status es 2xx (exitoso)\", function () {",
					"    pm.expect(pm.response.code).to.be.within(200, 299);",
					"});",
					"",
					"pm.test(\"Tiempo de respuesta < 3000ms\", function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(3000);",
					"});"
				]
			}
		}
	],
